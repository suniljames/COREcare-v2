# COREcare API — local development environment variables.
# Copy to api/.env to override Docker Compose defaults. When running via
# `docker compose up`, the compose file already provides DATABASE_URL and
# REDIS_URL pointing at the in-stack containers; this file is mainly for
# non-Docker workflows and for setting Clerk / Claude credentials.

# --- Database (Docker Compose default works as-is) ---
DATABASE_URL=postgresql+asyncpg://corecare:corecare@localhost:5432/corecare

# --- Redis (Docker Compose default works as-is) ---
REDIS_URL=redis://localhost:6379/0

# --- Clerk (OPTIONAL for local dev) ---
# Leave empty to use the dev fallback in api/app/auth.py: requests with no
# Authorization header receive a mock super_admin user. Set real keys only
# when you need to test live Clerk authentication end-to-end.
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=

# --- Claude API (OPTIONAL — only required for AI-powered endpoints) ---
# Without this, AI features will return errors. Get a key from
# https://console.anthropic.com/.
CLAUDE_API_KEY=

# --- Application ---
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=dev-secret-change-in-production

# --- Email (console transport works for local dev — see ADR-011 / #120) ---
EMAIL_TRANSPORT=console
EMAIL_FROM_ADDRESS=noreply@corecare.local
SENDGRID_API_KEY=
