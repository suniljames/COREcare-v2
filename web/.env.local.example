# COREcare web — local development environment variables.
# Copy to web/.env.local. The defaults below let the web app boot without
# any external accounts; supply real Clerk keys only when you need to test
# live sign-in.

# --- Clerk (stub keys boot the app without a Clerk account) ---
# This is the publicly-known dummy publishable key from Clerk's own examples.
# It passes Clerk's format validation at build time but cannot authenticate.
# Replace with your real pk_test_... when testing live sign-in.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_Y2xlcmsuaW5jbHVkZWQua2F0eWRpZC05Mi5sY2wuZGV2JA
# Leave empty to use the API's dev fallback (mock super_admin user). Set this
# when testing real Clerk auth alongside a real publishable key.
CLERK_SECRET_KEY=

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_API_URL=http://localhost:8000
